# Address of the deployed SquaredLedger contract on Monad Testnet.
# Filled in after running `forge script script/Deploy.s.sol --broadcast --rpc-url monad_testnet` in contracts/.
VITE_LEDGER_ADDRESS_TESTNET=

# Address of the deployed SquaredLedger contract on Monad Mainnet.
# Filled in after running `forge script script/Deploy.s.sol --broadcast --rpc-url monad_mainnet` in contracts/.
VITE_LEDGER_ADDRESS_MAINNET=

# Reown (WalletConnect) Cloud project ID — free at https://cloud.reown.com.
# Powers the multi-wallet connect modal (MetaMask, WalletConnect, Coinbase, etc).
VITE_REOWN_PROJECT_ID=
